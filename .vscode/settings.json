{
  "terminal.integrated.env.windows": {
    "_RUST_BACKTRACE": "full",
    "MIRIFLAGS": "-Zmiri-backtrace=full",
    "RUST_LOG": "info,shine_game=trace,shine_forge=trace,shine_infra=trace,test_map=trace",

    "SHINE_TEST_REDIS_CNS": "redis://redis.mockbox.com:6379",
    "SHINE_TEST_PG_CNS": "postgres://username:password@postgres.mockbox.com:5432/database-test?sslmode=disable"
  },
  "rust-analyzer.cargo.features": [],
  "rust-analyzer.cargo.target": "wasm32-unknown-unknown",
  "rust-analyzer.checkOnSave": false,
  "rust-analyzer.cargo.buildScripts.enable": false,  
  "rust-analyzer.procMacro.enable": false,
  "cSpell.customDictionaries": {
    "project-words": {
      "name": "project-words",
      "path": "${workspaceRoot}/cspell.json",
      "addWords": true
    }
  }
}
