{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "dist",
        "sourceMap": true,
        "paths": {
            "#wasm": ["./pkg/shine_game.js", "./src/wasm.d.ts"]
        }
    },
    "include": ["src", "eslint.config.ts", "vite.config.ts"]
}
