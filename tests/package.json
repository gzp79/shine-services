{
    "name": "integration-test",
    "version": "1.0.0",
    "description": "",
    "main": "test.js",
    "scripts": {
        "prepare": "cd .. && husky tests/.husky",
        "mkcert:ca": "mkcert create-ca --cert ../certs/ca.crt --key ../certs/ca.key",
        "mkcert": "pnpm run mkcert:ca && mkcert create-cert --ca-cert ../certs/ca.crt --ca-key ../certs/ca.key --cert ../certs/scytta.crt --key ../certs/scytta.key --domain cloud.local.scytta.com,mockbox.com",
        "build_service": "docker build --target test -t gzp79/shine-identity:test --progress=plain ..",
        "format": "prettier --write .",
        "lint": "pnpm run lint:format && pnpm run lint:eslint && pnpm run lint:build",
        "lint:format": "prettier --check .",
        "lint:eslint": "eslint .",
        "lint:build": "tsc -b --noEmit",
        "test:local": "playwright test",
        "mock:services": "tsx ./tools/mock_services"
    },
    "author": "",
    "license": "MIT",
    "engines": {
        "node": ">=18.18.2"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@playwright/test": "^1.58.2",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@trivago/prettier-plugin-sort-imports": "5.2.2",
        "@types/body-parser": "^1.19.6",
        "@types/cors": "^2.8.19",
        "@types/debug": "^4.1.13",
        "@types/eslint": "^9.6.1",
        "@types/eslint-config-prettier": "^6.11.3",
        "@types/express": "^5.0.6",
        "@types/express-serve-static-core": "^5.1.1",
        "@types/lodash": "^4.17.24",
        "@types/mailparser": "^3.4.6",
        "@types/node": "^24.12.0",
        "@types/nodemailer": "^7.0.11",
        "@types/smtp-server": "^3.5.12",
        "@types/uuid-validate": "^0.0.3",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "jiti": "^2.6.1",
        "mkcert": "^3.2.0",
        "prettier": "^3.8.1",
        "toxiproxy-node-client": "^4.0.0",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.2"
    },
    "dependencies": {
        "body-parser": "^2.2.2",
