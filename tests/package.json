        "express": "5.1.0",
        "express-serve-static-core": "^0.1.1",
        "express-validator": "^7.3.1",
        "html-entities": "^2.6.0",
        "lodash": "^4.17.23",
        "mailparser": "^3.9.6",
        "playwright": "^1.58.2",
        "smtp-server": "^3.18.3",
        "ts-jose": "^6.2.2",
        "uuid-validate": "^0.0.3",
